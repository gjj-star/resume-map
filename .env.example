# Resume Map V1 环境变量
# 用法：复制本文件为 .env 后填入，.env 已被 .gitignore 忽略，绝不入库。
# 也可在前端界面"自带 API Key"框填写，二者取其一（界面优先）。

# DeepSeek / 兼容模型 API Key
RM_API_KEY=

# 模型名（DeepSeek 默认；通义千问可用 deepseek-chat 替换策略见 README）
RM_MODEL=deepseek-chat

# OpenAI 兼容接口地址（换模型只改这里）
#   DeepSeek:  https://api.deepseek.com/v1/chat/completions
#   通义千问:  https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
RM_BASE_URL=https://api.deepseek.com/v1/chat/completions

# 服务端口
PORT=3000
